[Unit]
Description=monad-ops — validator node operational observability
After=network-online.target monad-execution.service
Wants=network-online.target

[Service]
Type=simple
User=<node-user>
Group=<node-user>
# Uncomment if your run-user is NOT already in `systemd-journal` via
# its primary group. The bft + execution tailers shell out to
# journalctl and need read access; without this the rule engine
# silently runs blind on consensus events.
#SupplementaryGroups=systemd-journal
WorkingDirectory=/opt/monad-ops
Environment=PYTHONUNBUFFERED=1
Environment=MONAD_OPS_CONFIG=/opt/monad-ops/config.toml
ExecStart=/opt/monad-ops/.venv/bin/python -m monad_ops.cli run
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Hardening (keep minimal — we need to read the journal and the node config)
NoNewPrivileges=true
ProtectSystem=full
PrivateTmp=true

[Install]
WantedBy=multi-user.target
