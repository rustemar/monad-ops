# monad-ops watchdog — Telegram credentials (template).
#
# Copy to scripts/watchdog.env (gitignored) and fill in real values,
# OR put the same key=value lines in a file referenced by the systemd
# unit's `EnvironmentFile=` directive — whichever your deployment
# prefers. Both paths end up setting these as env vars for the script.
#
# Bot token: created via @BotFather. Treat it like a password.
TG_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
# Chat/group ID where the bot sends alerts (usually negative for groups).
TG_CHAT_ID=-1000000000000
# Forum topic id (`message_thread_id`), or blank if the chat has no topics.
TG_TOPIC_ID=0
